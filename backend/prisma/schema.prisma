generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                        String             @id @default(cuid())
  username                  String             @unique
  password                  String
  createdAt                 DateTime           @default(now())
  avatarUrl                 String?
  bannerUrl                 String?
  description               String?
  isCreator                 Boolean            @default(false)
  creatorActivatedAt        DateTime?
  refreshTokens             RefreshToken[]
  posts                     Post[]
  comments                  Comment[]
  likes                     PostLike[]
  subscriptionTiers         SubscriptionTier[] @relation("author_tiers")
  subscriptionsAsSubscriber Subscription[]     @relation("subscriber_subscriptions")
  subscriptionsAsAuthor     Subscription[]     @relation("author_subscriptions")
  notifications             Notification[]     @relation("user_notifications")
  withdrawals               Withdrawal[]
  payments                  Payment[]          @relation("author_payments")

  @@map("users")
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([token])
  @@index([expiresAt])
  @@map("refresh_token")
}

model Post {
  id            String         @id @default(cuid())
  authorId      String
  author        User           @relation(fields: [authorId], references: [id], onDelete: Cascade)
  title         String
  description   String
  imageUrl      String?
  tags          String[]       @default([])
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  comments      Comment[]
  likes         PostLike[]
  notifications Notification[]

  isPaid       Boolean           @default(false)
  accessTierId String?
  accessTier   SubscriptionTier? @relation("SubscriptionTierPosts", fields: [accessTierId], references: [id], onDelete: SetNull)

  @@index([authorId, createdAt])
  @@map("posts")
}

model Comment {
  id        String   @id @default(cuid())
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  authorId  String
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  text      String
  createdAt DateTime @default(now())

  @@index([postId, createdAt])
  @@map("comments")
}

model PostLike {
  id        String   @id @default(cuid())
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([postId, userId])
  @@index([postId])
  @@index([userId])
  @@map("post_likes")
}

model SubscriptionTier {
  id          String   @id @default(cuid())
  authorId    String
  author      User     @relation("author_tiers", fields: [authorId], references: [id], onDelete: Cascade)
  title       String
  description String?
  imageUrl    String?
  priceCents  Int?
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  posts         Post[]         @relation("SubscriptionTierPosts")
  subscriptions Subscription[]

  @@index([authorId])
  @@map("subscription_tiers")
}

model Subscription {
  id              String            @id @default(cuid())
  subscriberId    String
  subscriber      User              @relation("subscriber_subscriptions", fields: [subscriberId], references: [id], onDelete: Cascade)
  authorId        String
  author          User              @relation("author_subscriptions", fields: [authorId], references: [id], onDelete: Cascade)
  tierId          String?
  tier            SubscriptionTier? @relation(fields: [tierId], references: [id], onDelete: SetNull)
  scheduledTierId String?
  kind            String            @default("follow")
  status          String            @default("active")
  durationMonths  Int               @default(1)
  startDate       DateTime          @default(now())
  expiresAt       DateTime?
  cancelledAt     DateTime?
  createdAt       DateTime          @default(now())

  @@unique([subscriberId, authorId, kind])
  @@index([authorId])
  @@index([subscriberId])
  @@index([expiresAt])
  @@index([kind])
  @@map("subscriptions")
}

model Notification {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation("user_notifications", fields: [userId], references: [id], onDelete: Cascade)
  type       String   @default("new_post")
  postId     String?
  post       Post?    @relation(fields: [postId], references: [id], onDelete: Cascade)
  authorName String
  message    String
  isRead     Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@index([userId, isRead])
  @@index([userId, createdAt])
  @@map("notifications")
}

model Withdrawal {
  id              String   @id @default(cuid())
  authorId        String
  author          User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  grossCents      Int
  commissionCents Int
  amountCents     Int
  status          String   @default("pending")
  createdAt       DateTime @default(now())

  @@index([authorId, createdAt])
  @@map("withdrawals")
}

model Payment {
  id           String   @id @default(cuid())
  authorId     String
  author       User     @relation("author_payments", fields: [authorId], references: [id], onDelete: Cascade)
  subscriberId String
  tierId       String?
  grossCents   Int
  kind         String   @default("subscription")
  createdAt    DateTime @default(now())

  @@index([authorId, createdAt])
  @@index([subscriberId])
  @@map("payments")
}
